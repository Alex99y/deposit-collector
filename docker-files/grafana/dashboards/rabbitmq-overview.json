        "targets": [
          {
            "expr": "sum(rabbitmq_detailed_queue_messages_ready)",
            "legendFormat": "ready",
            "refId": "A"
          },
          {
            "expr": "sum(rabbitmq_detailed_queue_messages_unacked)",
