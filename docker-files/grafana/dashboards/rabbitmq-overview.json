      {
        "type": "stat",
        "title": "Mensajes unacked (total)",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "targets": [
          {
            "expr": "sum(rabbitmq_detailed_queue_messages_unacked)",
            "refId": "A"
